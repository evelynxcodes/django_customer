<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Customers{% endblock %}</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 800px; margin: 40px auto; color: #222; }
        h1 { margin-bottom: 4px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { text-align: left; padding: 8px; border-bottom: 1px solid #ddd; }
        .actions a { margin-right: 10px; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; }
        .btn { display: inline-block; padding: 8px 14px; background: #2563eb; color: #fff;
               text-decoration: none; border-radius: 4px; border: none; cursor: pointer; font-size: 14px; }
        .btn.secondary { background: #6b7280; }
        .messages { list-style: none; padding: 0; }
        .messages li { background: #dcfce7; padding: 8px 12px; border-radius: 4px; margin-bottom: 10px; }
        form p { margin: 12px 0; }
        label { display: block; margin-bottom: 4px; font-weight: bold; }
        input[type=text], input[type=email] { width: 100%; padding: 6px; box-sizing: border-box; }
    </style>
</head>
<body>
    <div class="top-bar">
        <h1><a href="{% url 'customer_list' %}" style="text-decoration:none; color:inherit;">Customers</a></h1>
        <div>
            <a class="btn secondary" href="{% url 'export_customers_zip' %}">Download customers.zip</a>
            <a class="btn secondary" href="{% url 'download_project_zip' %}">Download project.zip</a>
        </div>
    </div>

    {% if messages %}
    <ul class="messages">
        {% for message in messages %}
        <li>{{ message }}</li>
        {% endfor %}
    </ul>
    {% endif %}

    {% block content %}{% endblock %}
</body>
</html>
